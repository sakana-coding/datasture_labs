{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Demo",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/build\" && clang++ -std=c++17 -g -I\"${workspaceFolder}/include\" \"${workspaceFolder}/src/main.cpp\" \"${workspaceFolder}/src/Myqueue.cpp\" -o \"${workspaceFolder}/build/demo\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "detail": "Build the queue demonstration executable into the build directory."
    }
  ]
}